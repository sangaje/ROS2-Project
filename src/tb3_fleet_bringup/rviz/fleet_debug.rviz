Panels:
  - Class: rviz_common/Displays
    Help Height: 85
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Status1
        - /Map1
        - /TF1
        - /Waffle Scan1
        - /Burger Scan1
        - /Waffle Pose1
        - /Burger Pose1
        - /Waffle Nav2 Plan1
        - /Burger Nav2 Plan1
        - /Fleet Debug Markers1
      Splitter Ratio: 0.5
    Tree Height: 375
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.44999998807907104
      Cell Size: 1
      Class: rviz_default_plugins/Grid
      Color: 160; 160; 164
      Enabled: true
      Line Style:
        Line Width: 0.029999999329447746
