      <builtin>
        <initialPeersList>
          <locator>
            <udpv4>
              <address>10.10.14.10</address>
            </udpv4>
          </locator>
          <locator>
            <udpv4>
              <address>10.10.14.14</address>
            </udpv4>
          </locator>
          <locator>
            <udpv4>
              <address>10.10.14.58</address>
