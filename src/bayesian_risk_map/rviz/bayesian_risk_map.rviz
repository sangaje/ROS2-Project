Panels:
  - Class: rviz_common/Displays
    Help Height: 70
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /SLAM Map1
        - /Risk Map Positive Halo1
        - /LaserScan1
      Splitter Ratio: 0.5
    Tree Height: 379
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
Visualization Manager:
