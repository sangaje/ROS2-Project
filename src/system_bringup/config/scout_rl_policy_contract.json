{
  "source_of_truth": {
    "training_runner": "run_train_v132_clean.sh",
    "train_module": "turtlebot3_rl_training.train_sac",
    "model_path": "rl_models/pure_velocity_sac_map64_lidar60_h8_deltatcn_domain22_nopriority_gsde_v022_dt02_b128/sac_turtlebot3_burger.zip"
  },
  "runtime": {
    "control_dt_sec": 0.2,
    "map_substeps_per_action": 2,
    "max_scan_age_sec": 0.5,
    "max_map_age_sec": 3.0,
    "max_tf_age_sec": 0.5,
    "max_inference_sec": 0.18,
    "command_timeout_sec": 0.25,
    "topics": {
      "scan": "/scan",
      "map": "/map",
      "map_frame": "map",
      "base_frame": "base_footprint",
      "scan_frame": "base_scan"
    },
    "map": {
      "resolution_m": 0.05,
      "initial_size_m": 8.0,
      "publish_every_n": 1,
      "keepalive_period_sec": 1.0,
      "confidence": {
        "clear_on_slam_occupied": false,
        "occupied_confirm_steps": 3,
        "decay_near_obstacle_scale": 0.0,
        "obstacle_ring_radius_cells": 5,
        "obstacle_floor_ratio": 1.0,
        "lidar_hit_guard_m": 0.05,
        "lidar_occlusion_radius_cells": 3
      }
    },
    "lidar": {
      "canonical_front_zero": true,
      "front_index": 0,
      "angle_offset_deg": 0.0,
      "flip_lr": false,
      "uniform_angle_resample": true,
      "median_kernel": 3,
      "lowpass_kernel": 5,
      "obstacle_margin_m": 0.08
    }
  },
  "policy": {
    "algorithm": "SAC",
    "loader": "stable_baselines3.SAC.load",
    "feature_extractor": "turtlebot3_rl_training.feature_extractor.MapVectorFeatureExtractor",
    "checkpoint_training_use_sde": true,
    "deterministic_inference": true,
    "sde_inference": false,
    "inference_noise_reset_calls": 0,
    "role_gate": "ACTIVE_SCOUT"
  },
  "observation_contract": {
    "type": "gymnasium.spaces.Dict",
    "keys": ["map", "map_seq", "seq", "vector"],
    "map": {
      "shape": [4, 64, 64],
      "dtype": "float32",
      "channels": [
        "slam_free",
        "slam_unknown",
        "slam_occupied",
        "confidence"
      ],
      "crop_size_m": 6.0,
      "robot_centered": true,
      "priority_channel": false
    },
    "map_seq": {
      "shape": [8, 4, 64, 64],
      "dtype": "float32"
    },
    "seq": {
      "shape": [8, 69],
      "dtype": "float32"
    },
    "vector": {
      "lidar_bins": 60,
      "stats_dim": 9,
      "shape": [69],
      "dtype": "float32"
    },
    "temporal": {
      "enabled": true,
      "history_len": 8,
      "startup_padding": "repeat first fresh observation, matching GazeboNavEnv history initialization",
      "takeover_reset": "clear history and repeat the first fresh observation"
    },
    "feature_dimensions": {
      "map": 48,
      "vector": 96,
      "temporal": 64,
      "combined": 192
    }
  },
  "action_contract": {
    "mode": "velocity",
    "shape": [2],
    "dtype": "float32",
    "low": [0.0, -0.7],
    "high": [0.22, 0.7],
    "linear_deadband": 0.02,
    "angular_deadband": 0.04,
    "smoothing_alpha": 0.65,
    "safety": {
      "backup": true,
      "slowdown": true,
      "slow_min_scale": 1.0,
      "trigger_distance_m": 0.22,
      "stop_distance_m": 0.22,
      "slow_distance_m": 0.40,
      "backup_speed_mps": 0.07,
      "turn_speed": 0.3,
      "backup_steps": 4,
      "cooldown_steps": 1
    }
  },
  "system_bringup_integration": {
    "leader_rl": false,
    "follower_rl": false,
    "recovery_navigation_rl": false,
    "localization_spin_rl": false,
    "active_scout_rl": true,
    "public_rl_launch_arguments": []
  }
}
